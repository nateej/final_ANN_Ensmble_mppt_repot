def train_model(train_data: Dict[str, np.ndarray], val_data: Dict[str, np.ndarray], cfg: Config):
    if cfg.model_mode == "mamba_pinn":
        raise ValueError("mamba_pinn is not enabled until real diode-physics residuals are implemented")
    if cfg.model_mode == "mlp_baseline":
        flat_dataset = build_dataset_from_curves(train_data["curves"], cfg.sample_fracs, cfg)
        return {"kind": "mlp", "bundle": train_ensemble(flat_dataset, cfg)}

    x_tr = torch.tensor(train_data["X_seq"], dtype=torch.float32, device=cfg.device)
    yv_tr = torch.tensor(train_data["y_vhat_true"], dtype=torch.float32, device=cfg.device)
    yp_tr = torch.tensor(train_data["y_power_true"], dtype=torch.float32, device=cfg.device)
    yc_tr = torch.tensor(train_data["y_coarse_vhat"], dtype=torch.float32, device=cfg.device)

    x_va = torch.tensor(val_data["X_seq"], dtype=torch.float32, device=cfg.device)
    yv_va = torch.tensor(val_data["y_vhat_true"], dtype=torch.float32, device=cfg.device)
    yp_va = torch.tensor(val_data["y_power_true"], dtype=torch.float32, device=cfg.device)
    yc_va = torch.tensor(val_data["y_coarse_vhat"], dtype=torch.float32, device=cfg.device)

    model = MambaVhatNet(in_features=x_tr.shape[-1], d_model=cfg.d_model, n_blocks=cfg.n_blocks, dropout=cfg.seq_dropout).to(cfg.device)
    opt = optim.AdamW(model.parameters(), lr=cfg.lr, weight_decay=cfg.weight_decay)

    def lr_lambda(ep):
        if ep < cfg.warmup_epochs:
            return max((ep + 1) / max(cfg.warmup_epochs, 1), 1e-3)
        t = (ep - cfg.warmup_epochs) / max(cfg.epochs - cfg.warmup_epochs, 1)
        return cfg.min_lr / cfg.lr + 0.5 * (1 - cfg.min_lr / cfg.lr) * (1 + np.cos(np.pi * t))

    sch = optim.lr_scheduler.LambdaLR(opt, lr_lambda=lr_lambda)
    bs = cfg.batch_size
    best = (1e9, None)

    for ep in range(cfg.epochs):
        model.train()
        perm = torch.randperm(x_tr.shape[0], device=cfg.device)
        for st in range(0, x_tr.shape[0], bs):
            bi = perm[st:st + bs]
            xb, yvb, ypb, ycb = x_tr[bi], yv_tr[bi], yp_tr[bi], yc_tr[bi]
            opt.zero_grad()
            pred = model(xb)
            if cfg.model_mode == "mamba_pinn":
                loss = pinn_loss(pred, yvb, ypb, ycb, xb, cfg)
            else:
                loss, _ = supervised_power_first_loss(pred, yvb, ypb, ycb, xb, cfg)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), cfg.grad_clip_norm)
            opt.step()
        sch.step()

        model.eval()
        with torch.no_grad():
            pv = model(x_va)
            if cfg.model_mode == "mamba_pinn":
                vloss = nn.SmoothL1Loss()(pv, yv_va).item()
            else:
                vloss = supervised_power_first_loss(pv, yv_va, yp_va, yc_va, x_va, cfg)[0].item()
        if vloss < best[0]:
            best = (vloss, {k: v.detach().cpu().clone() for k, v in model.state_dict().items()})

    if best[1] is not None:
        model.load_state_dict(best[1])
    return {"kind": cfg.model_mode, "model": model}

def _predict_ann_vhat_for_curve(curve_item, trained, cfg: Config):
    oracle = CurveOracle(curve_item)
    v_plot, i_plot = oracle.curve_for_plot()
    feat = build_feature_vector(v_plot, i_plot, cfg.sample_fracs)
    if trained["kind"] == "mlp":
        models, mu, sd, _, _, residual_scale = trained["bundle"]
        x_std = (feat["x"] - mu) / sd
        ens = predict_vhat_ensemble(models, x_std, float(feat["coarse_best_vhat"]), residual_scale, cfg.device)
        return float(ens["pred_vhat_mean"])

    seq = build_sequence_dataset_from_curves([curve_item], cfg.sample_fracs, cfg, augment=False)
    if len(seq["X_seq"]) == 0:
        return float(feat["coarse_best_vhat"])
    x = torch.tensor(seq["X_seq"], dtype=torch.float32, device=cfg.device)
    with torch.no_grad():
        vhat = float(trained["model"](x).detach().cpu().numpy()[0])
    return float(np.clip(vhat, 0.0, 1.0))

def evaluate_ann_only(test_curves, trained, cfg: Config):
    rows = []
    for item in list(iter_curve_items(test_curves)):
        oracle = CurveOracle(item)
        if oracle.voc <= 0 or oracle.pmpp_true <= 0:
            continue
        v_plot, i_plot = oracle.curve_for_plot()
        feat = build_feature_vector(v_plot, i_plot, cfg.sample_fracs)
        coarse_vhat = float(feat["coarse_best_vhat"])
        ann_vhat = _predict_ann_vhat_for_curve(item, trained, cfg)
        V_true, P_true = float(oracle.vmpp_true), float(oracle.pmpp_true)
        V_coarse_best = float(coarse_vhat * oracle.voc)
        P_coarse_best = float(V_coarse_best * oracle.measure(V_coarse_best))
        V_ann = float(ann_vhat * oracle.voc)
        P_ann = float(V_ann * oracle.measure(V_ann))
        coarse_ratio_pct = 100.0 * P_coarse_best / max(P_true, 1e-9)
        ann_ratio_pct = 100.0 * P_ann / max(P_true, 1e-9)
        coarse_reg = 100.0 * max(P_true - P_coarse_best, 0.0) / max(P_true, 1e-9)
        ann_reg = 100.0 * max(P_true - P_ann, 0.0) / max(P_true, 1e-9)
        rows.append({
            "V_true": V_true, "P_true": P_true,
            "V_coarse_best": V_coarse_best, "P_coarse_best": P_coarse_best,
            "V_ann": V_ann, "P_ann": P_ann,
            "coarse_ratio_pct": coarse_ratio_pct, "ann_ratio_pct": ann_ratio_pct,
            "coarse_power_regret_pct": coarse_reg, "ann_power_regret_pct": ann_reg,
            "ann_better_than_coarse_power": int(P_ann > P_coarse_best + 1e-9),
            "ann_worse_than_coarse_power": int(P_ann + 1e-9 < P_coarse_best),
        })
    df = pd.DataFrame(rows)
    if len(df) == 0:
        return {}, df
    summary = {
        "mean_coarse_ratio_pct": float(df["coarse_ratio_pct"].mean()),
        "mean_ann_ratio_pct": float(df["ann_ratio_pct"].mean()),
        "ann_power_gain_vs_coarse_pct_points": float(df["ann_ratio_pct"].mean() - df["coarse_ratio_pct"].mean()),
        "ann_better_than_coarse_power_rate": float(100.0 * df["ann_better_than_coarse_power"].mean()),
        "ann_worse_than_coarse_power_rate": float(100.0 * df["ann_worse_than_coarse_power"].mean()),
        "mean_ann_power_regret_pct": float(df["ann_power_regret_pct"].mean()),
        "mean_coarse_power_regret_pct": float(df["coarse_power_regret_pct"].mean()),
        "ann_within_1pct_power_regret_rate": float(100.0 * (df["ann_power_regret_pct"] <= 1.0).mean()),
        "ann_within_2pct_power_regret_rate": float(100.0 * (df["ann_power_regret_pct"] <= 2.0).mean()),
        "ann_within_5pct_power_regret_rate": float(100.0 * (df["ann_power_regret_pct"] <= 5.0).mean()),
    }
    return summary, df

def evaluate_supervised_ann(test_curves, trained, cfg: Config):
    return evaluate_ann_only(test_curves, trained, cfg)

def run_ablations(sim_test_curves, exp_curves, trained_models_by_mode, cfg: Config):
    rows = []
    for mode_name, trained in trained_models_by_mode.items():
        sim_summary, _ = evaluate_ann_only(sim_test_curves, trained, cfg)
        exp_summary, _ = evaluate_ann_only(exp_curves, trained, cfg)
        if len(sim_summary) == 0 or len(exp_summary) == 0:
            continue
        for split_name, summary in (("sim_holdout_test", sim_summary), ("exp_unseen_test", exp_summary)):
            row = {"mode": mode_name, "split": split_name}
            row.update(summary)
            rows.append(row)
    df = pd.DataFrame(rows)
    if len(df) > 0:
        df.to_csv("ann_only_ablation_table.csv", index=False)
        torch.save(df.to_dict(orient="records"), "ann_only_ablation_table.pt")
    return df

def evaluate_power_metrics(summary: Dict[str, float]):
    return {
        "pass_mean_ratio": summary.get("mean_ann_ratio_pct", -1) > summary.get("mean_coarse_ratio_pct", 1e9),
        "pass_gain": summary.get("ann_power_gain_vs_coarse_pct_points", -1) > 0,
        "pass_better_rate": summary.get("ann_better_than_coarse_power_rate", 0) >= 60.0,
        "pass_regret": summary.get("mean_ann_power_regret_pct", 1e9) < summary.get("mean_coarse_power_regret_pct", -1),
    }

