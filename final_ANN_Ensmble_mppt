try:
    from mamba_ssm import Mamba  # type: ignore
except Exception:
    Mamba = None

class _FallbackMambaBlock(nn.Module):
    def __init__(self, d_model, dropout=0.05):
        super().__init__()
        self.ff = nn.Sequential(nn.Linear(d_model, d_model), nn.GELU(), nn.Dropout(dropout), nn.Linear(d_model, d_model))
        self.ln = nn.LayerNorm(d_model)
    def forward(self, x):
        return self.ln(x + self.ff(x))

class MambaVhatNet(nn.Module):
    def __init__(self, in_features: int, d_model: int = 64, n_blocks: int = 2, dropout: float = 0.05):
        super().__init__()
        self.proj = nn.Linear(in_features, d_model)
        blocks = []
        for _ in range(int(n_blocks)):
            if Mamba is not None:
                blocks.append(nn.Sequential(Mamba(d_model=d_model, d_state=16, d_conv=4, expand=2), nn.Dropout(dropout)))
            else:
                blocks.append(_FallbackMambaBlock(d_model=d_model, dropout=dropout))
        self.blocks = nn.ModuleList(blocks)
        self.head = nn.Sequential(nn.Linear(d_model, d_model // 2), nn.GELU(), nn.Linear(d_model // 2, 1), nn.Sigmoid())

    def forward(self, x):
        h = self.proj(x)
        for blk in self.blocks:
            h = blk(h)
        out = self.head(h[:, -1, :]).squeeze(-1)
        return torch.clamp(out, 0.0, 1.0)

