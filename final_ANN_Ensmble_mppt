def evaluate_unseen_300(exp_curves, models, mu, sd, residual_scale, cfg: Config, controller_fn=run_hybrid_episode_logged):
    exp_list = np.asarray(exp_curves).ravel()

    valid_indices = []
    for idx, item in enumerate(exp_list):
        oracle = CurveOracle(item)
        if oracle.voc > 0 and oracle.pmpp_true > 0:
            valid_indices.append(idx)

    if len(valid_indices) == 0:
        raise RuntimeError("No valid unseen/test curves found after cleaning.")

    eval_indices = valid_indices[:min(cfg.max_eval_curves, len(valid_indices))]

    rows = []
    examples = []

    for idx in eval_indices:
        oracle = CurveOracle(exp_list[idx])
        v, i = oracle.curve_for_plot()
        feat = build_feature_vector(v, i, cfg.sample_fracs)

        x_std = apply_standardizer(feat["x"][None, :], mu, sd)
        coarse_best_vhat = float(feat["coarse_best_vhat"])
        ens = predict_vhat_ensemble(models, x_std, coarse_best_vhat, residual_scale, cfg.device)

        V_ann = float(np.clip(ens["mean_vhat"] * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
        P_ann = float(V_ann * oracle.measure(V_ann))
        V_coarse_best = float(coarse_best_vhat * oracle.voc)
        P_coarse_best = float(V_coarse_best * oracle.measure(V_coarse_best))

        ann_diff_pct = 100.0 * abs(V_ann - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        coarse_diff_pct = 100.0 * abs(V_coarse_best - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        ann_err_abs = abs(V_ann - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        coarse_err_abs = abs(V_coarse_best - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        ann_beats_coarse = int(ann_err_abs < coarse_err_abs)
        ann_equals_or_beats_coarse = int(ann_err_abs <= coarse_err_abs)
        ann_power_regret_pct = 100.0 * max(oracle.pmpp_true - P_ann, 0.0) / (abs(oracle.pmpp_true) + 1e-9)

        hybrid_res, hybrid_log = controller_fn(oracle, models, mu, sd, residual_scale, cfg)
        final_vdiff_pct = 100.0 * abs(hybrid_log["V_best"] - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        final_power_regret_pct = 100.0 * max(oracle.pmpp_true - hybrid_log["P_best"], 0.0) / (abs(oracle.pmpp_true) + 1e-9)
        stage_stats = hybrid_res.get("stage_stats", {})
        total_points = int(sum(stage_stats.get(k, 0) for k in [
            "coarse_points", "ann_points", "refine_points", "dual_rescue_points",
            "top3_rescue_points", "fallback_targeted_points", "fallback_wide_points"
        ]))
        hold_frac = float(hybrid_res.get("total_hold_time", 0.0) / max(hybrid_res["time"], 1e-12))

        rows.append({
            "curve_idx": int(idx),
            "Voc": float(oracle.voc),
            "V_true": float(oracle.vmpp_true),
            "P_true": float(oracle.pmpp_true),
            "V_coarse_best": V_coarse_best,
            "coarse_diff_pct": coarse_diff_pct,
            "V_ann": V_ann,
            "ann_diff_pct": ann_diff_pct,
            "ann_beats_coarse": ann_beats_coarse,
            "ann_equals_or_beats_coarse": ann_equals_or_beats_coarse,
            "ann_power_regret_pct": ann_power_regret_pct,
            "ann_std_vhat": float(ens["std_vhat"]),
            "V_final_hybrid": float(hybrid_log["V_best"]),
            "final_hybrid_vdiff_pct": final_vdiff_pct,
            "final_hybrid_power_regret_pct": final_power_regret_pct,
            "final_ratio_pct": 100.0 * float(hybrid_res["ratio"]),
            "tracking_eff_pct": 100.0 * float(hybrid_res["eff"]),
            "fallback": int(hybrid_res["fallback"]),
            "ambiguous_case": int(hybrid_res["ambiguous_case"]),
            "uncertain_ann": int(hybrid_res["uncertain_ann"]),
            "dual_peak_rescue_used": int(hybrid_res["dual_peak_rescue_used"]),
            "top3_rescue_used": int(hybrid_res["top3_rescue_used"]),
            "episode_time_s": float(hybrid_res["time"]),
            "mode": hybrid_res.get("mode", "global"),
            "n_eval_points": total_points,
            "hold_time_fraction": hold_frac,
            "total_probe_time_s": float(hybrid_res.get("total_probe_time", 0.0)),
            "total_hold_time_s": float(hybrid_res.get("total_hold_time", 0.0)),
        })

        examples.append({
            "idx": int(idx),
            "oracle": oracle,
            "V_ann": V_ann,
            "P_ann": P_ann,
            "V_coarse": np.asarray(hybrid_log["coarse_V"], dtype=float),
            "P_coarse": np.asarray(hybrid_log["coarse_P"], dtype=float),
            "V_coarse_best": V_coarse_best,
            "P_coarse_best": P_coarse_best,
            "V_final": float(hybrid_log["V_best"]),
            "P_final": float(hybrid_log["P_best"]),
            "fallback": bool(hybrid_res["fallback"]),
            "ambiguous_case": bool(hybrid_res["ambiguous_case"]),
            "uncertain_ann": bool(hybrid_res["uncertain_ann"]),
            "dual_peak_rescue_used": bool(hybrid_res["dual_peak_rescue_used"]),
            "top3_rescue_used": bool(hybrid_res["top3_rescue_used"]),
            "ann_diff_pct": ann_diff_pct,
            "final_vdiff_pct": final_vdiff_pct,
        })

    df = pd.DataFrame(rows)
    summary = {
        "n_eval_valid": int(len(df)),
        "mean_ann_diff_pct": float(df["ann_diff_pct"].mean()),
        "median_ann_diff_pct": float(df["ann_diff_pct"].median()),
        "max_ann_diff_pct": float(df["ann_diff_pct"].max()),
        "ann_within_5pct_rate": float(100.0 * (df["ann_diff_pct"] <= 5.0).mean()),
        "ann_pass_avg_diff_le_5pct": bool(df["ann_diff_pct"].mean() <= 5.0),
        "mean_coarse_diff_pct": float(df["coarse_diff_pct"].mean()),
        "ann_improvement_vs_coarse_pct_points": float(df["coarse_diff_pct"].mean() - df["ann_diff_pct"].mean()),
        "ann_beats_coarse_rate_pct": float(100.0 * df["ann_beats_coarse"].mean()),
        "ann_equals_or_beats_coarse_rate_pct": float(100.0 * df["ann_equals_or_beats_coarse"].mean()),
        "mean_final_hybrid_vdiff_pct": float(df["final_hybrid_vdiff_pct"].mean()),
        "max_final_hybrid_vdiff_pct": float(df["final_hybrid_vdiff_pct"].max()),
        "mean_final_ratio_pct": float(df["final_ratio_pct"].mean()),
        "mean_tracking_eff_pct": float(df["tracking_eff_pct"].mean()),
        "mean_final_hybrid_power_regret_pct": float(df["final_hybrid_power_regret_pct"].mean()),
        "fallback_rate_pct": float(100.0 * df["fallback"].mean()),
        "ambiguous_case_rate_pct": float(100.0 * df["ambiguous_case"].mean()),
        "uncertain_ann_rate_pct": float(100.0 * df["uncertain_ann"].mean()),
        "dual_peak_rescue_rate_pct": float(100.0 * df["dual_peak_rescue_used"].mean()),
        "top3_rescue_rate_pct": float(100.0 * df["top3_rescue_used"].mean()),
        "mean_episode_time_s": float(df["episode_time_s"].mean()),
        "avg_eval_points_per_episode": float(df["n_eval_points"].mean()),
        "avg_hold_time_fraction": float(df["hold_time_fraction"].mean()),
    }
    return summary, df, examples

def evaluate_static_ab(exp_curves, models, mu, sd, residual_scale, cfg: Config):
    baseline_cfg = Config(**cfg.__dict__)
    baseline_cfg.use_adaptive_hold = False
    baseline_cfg.use_lean_global_runtime = False
    baseline_cfg.enable_top3_rescue = True
    baseline_cfg.max_refine_iterations = 10
    baseline_cfg.dual_rescue_offsets = (-0.06, -0.03, 0.0, 0.03, 0.06)
    baseline_cfg.widen_scan_steps = 10
    baseline_summary, baseline_df, _ = evaluate_unseen_300(
        exp_curves, models, mu, sd, residual_scale, baseline_cfg, controller_fn=run_global_gmppt_episode_logged
    )
    opt_summary, opt_df, _ = evaluate_unseen_300(
        exp_curves, models, mu, sd, residual_scale, cfg, controller_fn=run_global_gmppt_episode_logged
    )
    comp = pd.DataFrame([
        {"controller": "baseline", **baseline_summary},
        {"controller": "optimized", **opt_summary},
    ])
    return comp, baseline_df, opt_df

def evaluate_loss_ablation(exp_curves, dataset, cfg):
    baseline_cfg = Config(**cfg.__dict__)
    baseline_cfg.improvement_loss_enabled = False
    baseline_cfg.residual_scale_quantile = 0.995
    baseline_cfg.residual_scale_margin = 1.10

    improved_cfg = Config(**cfg.__dict__)
    improved_cfg.improvement_loss_enabled = True
    improved_cfg.residual_scale_quantile = 0.98
    improved_cfg.residual_scale_margin = 1.00

    # Train baseline
    baseline_models, baseline_mu, baseline_sd, baseline_histories, baseline_best_losses, baseline_residual_scale = train_ensemble(dataset, baseline_cfg)
    print("\nBaseline loss best validation loss per model:")
    for i, loss in enumerate(baseline_best_losses, 1):
        print(f"  model {i}: {loss:.6f}")
    baseline_summary, baseline_df, _ = evaluate_unseen_300(
        exp_curves, baseline_models, baseline_mu, baseline_sd, baseline_residual_scale, baseline_cfg,
        controller_fn=run_global_gmppt_episode_logged
    )

    # Train improved-loss version
    improved_models, improved_mu, improved_sd, improved_histories, improved_best_losses, improved_residual_scale = train_ensemble(dataset, improved_cfg)
    print("\nImprovement-aware loss best validation loss per model:")
    for i, loss in enumerate(improved_best_losses, 1):
        print(f"  model {i}: {loss:.6f}")
    improved_summary, improved_df, _ = evaluate_unseen_300(
        exp_curves, improved_models, improved_mu, improved_sd, improved_residual_scale, improved_cfg,
        controller_fn=run_global_gmppt_episode_logged
    )

    comp = pd.DataFrame([
        {"experiment": "baseline_loss", **baseline_summary},
        {"experiment": "improvement_aware_loss", **improved_summary},
    ])
    return comp, baseline_df, improved_df, baseline_histories, improved_histories

def evaluate_transition_sequences(curve_sequence, models, mu, sd, residual_scale, cfg):
    state = RuntimeState()
    rows = []
    for step_idx, curve in enumerate(curve_sequence):
        oracle = CurveOracle(curve)
        if oracle.voc <= 0 or oracle.pmpp_true <= 0:
            continue
        result, log, state = run_hybrid_supervised_step(oracle, state, models, mu, sd, residual_scale, cfg)
        rows.append({
            "step": step_idx,
            "mode": log["mode"],
            "step_time_s": float(result["time"]),
            "tracking_eff": float(result["eff"]),
            "final_ratio": float(result["ratio"]),
        })
    if len(rows) == 0:
        return {"n_steps": 0}, pd.DataFrame()
    df = pd.DataFrame(rows)
    summary = {
        "n_steps": int(len(df)),
        "local_mode_fraction": float((df["mode"] == "local").mean()),
        "global_mode_fraction": float((df["mode"] == "global").mean()),
        "mean_step_time_s": float(df["step_time_s"].mean()),
        "p95_step_time_s": float(df["step_time_s"].quantile(0.95)),
        "worst_step_time_s": float(df["step_time_s"].max()),
        "energy_weighted_tracking_eff": float(np.average(df["tracking_eff"], weights=np.maximum(df["step_time_s"], 1e-9))),
        "recovery_quality_after_transitions": float(df["final_ratio"].mean()),
    }
    return summary, df

def evaluate_transition_ab(curve_sequence, models, mu, sd, residual_scale, cfg: Config):
    baseline_cfg = Config(**cfg.__dict__)
    baseline_cfg.use_event_triggered_global = False

    baseline_summary, baseline_df = evaluate_transition_sequences(curve_sequence, models, mu, sd, residual_scale, baseline_cfg)
    supervised_summary, supervised_df = evaluate_transition_sequences(curve_sequence, models, mu, sd, residual_scale, cfg)

    comp = pd.DataFrame([
        {"controller": "global_every_step_baseline", **baseline_summary},
        {"controller": "supervisory_local_global", **supervised_summary},
    ])
    return comp, baseline_df, supervised_df

