@dataclass
class StageStats:
    coarse_points: int = 0
    ann_points: int = 0
    refine_points: int = 0
    dual_rescue_points: int = 0
    top3_rescue_points: int = 0
    fallback_targeted_points: int = 0
    fallback_wide_points: int = 0
    t_probe_total: float = 0.0
    t_hold_total: float = 0.0

@dataclass
class RuntimeState:
    initialized: bool = False
    last_v_best: float = 0.0
    last_p_best: float = 0.0
    last_mode: str = "global"
    last_v_observed: Optional[float] = None
    last_p_observed: Optional[float] = None

def add_probe(E: float, t: float, P: float, dt: float) -> Tuple[float, float]:
    return E + P * dt, t + dt

def add_hold(E: float, t: float, P: float, dt: float) -> Tuple[float, float]:
    return E + P * dt, t + dt

def add_adaptive_hold(E: float, t: float, p_before: float, p_after: float, cfg: Config):
    if not cfg.use_adaptive_hold:
        E, t = add_hold(E, t, p_after, cfg.dt_hold)
        return E, t, cfg.dt_hold
    improved = p_after > p_before * (1.0 + cfg.confirm_gain_eps_ratio)
    hold_dt = cfg.dt_hold_confirm if improved else cfg.dt_hold_probe
    E, t = add_hold(E, t, p_after, hold_dt)
    return E, t, hold_dt

def evaluate_point(oracle: CurveOracle, vq: float) -> Tuple[float, float]:
    vq = float(np.clip(vq, 0.0, oracle.voc))
    iq = oracle.measure(vq)
    return vq, float(vq * iq)

def maybe_update_best(vq: float, pq: float, V_best: float, P_best: float):
    if pq > P_best:
        return float(vq), float(pq), True
    return V_best, P_best, False

def detect_ambiguity_from_coarse(V_coarse: np.ndarray, P_coarse: np.ndarray, cfg: Config) -> Dict[str, float]:
    if len(P_coarse) < 2:
        return {
            "ambiguous": False,
            "best_idx": 0,
            "second_idx": 0,
            "third_idx": 0,
            "gap_ratio": 1.0,
            "sep_frac": 0.0,
            "n_local_max": 0,
        }

    order_desc = np.argsort(P_coarse)[::-1]
    best_idx = int(order_desc[0])
    second_idx = int(order_desc[1]) if len(order_desc) >= 2 else best_idx
    third_idx = int(order_desc[2]) if len(order_desc) >= 3 else second_idx

    P1 = float(P_coarse[best_idx])
    P2 = float(P_coarse[second_idx])
    V1 = float(V_coarse[best_idx])
    V2 = float(V_coarse[second_idx])

    gap_ratio = float((P1 - P2) / (abs(P1) + 1e-12))
    sep_frac = float(abs(V1 - V2) / (max(float(np.max(V_coarse)), 1e-12)))
    n_local_max = count_local_maxima(P_coarse, noise_tolerance=0.02)

    ambiguous = (
        (gap_ratio <= cfg.ambiguity_power_gap_pct and sep_frac >= cfg.ambiguity_min_voltage_gap_frac)
        or (n_local_max >= cfg.shading_peak_threshold)
    )

    return {
        "ambiguous": bool(ambiguous),
        "best_idx": best_idx,
        "second_idx": second_idx,
        "third_idx": third_idx,
        "gap_ratio": gap_ratio,
        "sep_frac": sep_frac,
        "n_local_max": n_local_max,
    }

def run_targeted_rescue(
    oracle: CurveOracle,
    candidate_centers: List[float],
    offsets: Tuple[float, ...],
    cfg: Config,
    E: float,
    t: float,
    log: Dict,
    V_best: float,
    P_best: float,
    tag: str,
    stats: StageStats,
):
    visited = set()
    for center in candidate_centers:
        for off in offsets:
            vq = float(np.clip(center * (1.0 + off), cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
            key = round(vq, 6)
            if key in visited:
                continue
            visited.add(key)

            v_eval, p_eval = evaluate_point(oracle, vq)
            E, t = add_probe(E, t, p_eval, cfg.dt_meas)
            stats.t_probe_total += cfg.dt_meas
            if tag == "dual_peak_rescue":
                stats.dual_rescue_points += 1
            elif tag == "top3_rescue":
                stats.top3_rescue_points += 1
            elif tag == "fallback_targeted":
                stats.fallback_targeted_points += 1
            log["meas_V"].append(float(v_eval))
            log["meas_P"].append(float(p_eval))
            log["meas_tag"].append(tag)

            p_before = P_best
            V_best, P_best, _ = maybe_update_best(v_eval, p_eval, V_best, P_best)
            E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
            stats.t_hold_total += hold_dt

    return E, t, V_best, P_best

def split_experimental_curves(exp_curves, frac=0.5, seed=7):
    valid = []
    for item in iter_curve_items(exp_curves):
        oracle = CurveOracle(item)
        if oracle.voc > 0 and oracle.pmpp_true > 0:
            valid.append(item)

    rng = np.random.RandomState(seed)
    idx = np.arange(len(valid))
    rng.shuffle(idx)

    n_cal = int(len(valid) * frac)
    if len(valid) >= 2:
        n_cal = max(1, min(n_cal, len(valid) - 1))
    else:
        n_cal = min(n_cal, len(valid))
    cal_idx = idx[:n_cal]
    hold_idx = idx[n_cal:]

    cal_curves = [valid[i] for i in cal_idx]
    hold_curves = [valid[i] for i in hold_idx]

    # IMPORTANT: return plain Python lists, NOT np.array(..., dtype=object)
    return cal_curves, hold_curves

def build_trust_gate_dataset(curves, models, mu, sd, residual_scale, cfg):
    rows = []
    gate_columns = [
        "ann_std_vhat",
        "ann_shift_from_coarse",
        "coarse_top_gap_ratio",
        "ambiguity_flag",
        "multi_peak_count",
        "ensemble_range_vhat",
        "ann_beats_coarse",
        "ann_err_pct",
        "coarse_err_pct",
    ]
    for item in iter_curve_items(curves):
        oracle = CurveOracle(item)
        if oracle.voc <= 0 or oracle.pmpp_true <= 0:
            continue

        v, i = oracle.curve_for_plot()
        feat = build_feature_vector(v, i, cfg.sample_fracs)

        x_std = apply_standardizer(feat["x"][None, :], mu, sd)
        coarse_best_vhat = float(feat["coarse_best_vhat"])
        coarse_top_gap_ratio = float(feat["top_gap_ratio"])
        ambiguity_flag = float(feat["ambiguity_flag"])
        multi_peak_count = float(feat["multi_peak_count"])

        ens = predict_vhat_ensemble(models, x_std, coarse_best_vhat, residual_scale, cfg.device)

        ann_vhat = float(ens["mean_vhat"])
        ann_std_vhat = float(ens["std_vhat"])
        ensemble_range_vhat = float(ens["max_vhat"] - ens["min_vhat"])
        ann_shift_from_coarse = abs(ann_vhat - coarse_best_vhat)

        V_ann = float(np.clip(ann_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
        V_coarse = float(coarse_best_vhat * oracle.voc)

        ann_err = abs(V_ann - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        coarse_err = abs(V_coarse - oracle.vmpp_true) / (abs(oracle.vmpp_true) + 1e-9)
        ann_beats_coarse = int(ann_err < coarse_err)

        rows.append({
            "ann_std_vhat": ann_std_vhat,
            "ann_shift_from_coarse": ann_shift_from_coarse,
            "coarse_top_gap_ratio": coarse_top_gap_ratio,
            "ambiguity_flag": ambiguity_flag,
            "multi_peak_count": multi_peak_count,
            "ensemble_range_vhat": ensemble_range_vhat,
            "ann_beats_coarse": ann_beats_coarse,
            "ann_err_pct": 100.0 * ann_err,
            "coarse_err_pct": 100.0 * coarse_err,
        })

    return pd.DataFrame(rows, columns=gate_columns)

def fit_trust_gate(cal_df, cfg):
    feature_names = [f for f in cfg.trust_gate_use_features if f in cal_df.columns]
    if len(feature_names) == 0 or "ann_beats_coarse" not in cal_df.columns or len(cal_df) == 0:
        return None, feature_names

    X = cal_df[feature_names].values
    y = cal_df["ann_beats_coarse"].values.astype(int)
    if np.unique(y).size < 2:
        return None, feature_names

    model = LogisticRegression(
        random_state=cfg.trust_gate_random_state,
        max_iter=1000,
        class_weight="balanced"
    )
    model.fit(X, y)
    return model, feature_names

def choose_trust_threshold(cal_df, gate_model, feature_names):
    if gate_model is None or not feature_names:
        return 0.60, float("nan")

    X = cal_df[feature_names].values
    probs = gate_model.predict_proba(X)[:, 1]

    best_thresh = 0.60
    best_score = float("inf")

    for thresh in np.linspace(0.50, 0.90, 17):
        use_ann = probs >= thresh
        selected_err = np.where(
            use_ann,
            cal_df["ann_err_pct"].values,
            cal_df["coarse_err_pct"].values
        )
        score = selected_err.mean()
        if score < best_score:
            best_score = score
            best_thresh = float(thresh)

    return best_thresh, float(best_score)

def predict_ann_stage_for_oracle(oracle: CurveOracle, models, mu, sd, residual_scale, cfg: Config):
    v, i = oracle.curve_for_plot()
    feat = build_feature_vector(v, i, cfg.sample_fracs)
    x = feat["x"][None, :]
    x_std = apply_standardizer(x, mu, sd)
    coarse_best_vhat = float(feat["coarse_best_vhat"])

    ens = predict_vhat_ensemble(models, x_std, coarse_best_vhat, residual_scale, cfg.device)
    pred_vhat = ens["mean_vhat"]
    V_pred = float(np.clip(pred_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))

    return {
        "feature": feat,
        "V_pred": V_pred,
        "P_pred": float(V_pred * oracle.measure(V_pred)),
        "pred_vhat_mean": float(ens["mean_vhat"]),
        "pred_vhat_std": float(ens["std_vhat"]),
        "pred_vhat_min": float(ens["min_vhat"]),
        "pred_vhat_max": float(ens["max_vhat"]),
    }

def predict_ann_stage_with_trust_gate(
    oracle,
    models,
    mu,
    sd,
    residual_scale,
    cfg,
    gate_model=None,
    gate_feature_names=None,
    trust_threshold=None,
):
    v, i = oracle.curve_for_plot()
    feat = build_feature_vector(v, i, cfg.sample_fracs)
    x = feat["x"][None, :]
    x_std = apply_standardizer(x, mu, sd)

    coarse_best_vhat = float(feat["coarse_best_vhat"])
    coarse_top_gap_ratio = float(feat["top_gap_ratio"])
    ambiguity_flag = float(feat["ambiguity_flag"])
    multi_peak_count = float(feat["multi_peak_count"])

    ens = predict_vhat_ensemble(models, x_std, coarse_best_vhat, residual_scale, cfg.device)

    ann_vhat = float(ens["mean_vhat"])
    ann_std_vhat = float(ens["std_vhat"])
    ensemble_range_vhat = float(ens["max_vhat"] - ens["min_vhat"])
    ann_shift_from_coarse = abs(ann_vhat - coarse_best_vhat)

    trust_prob = None
    trust_ann = True

    if cfg.trust_gate_enabled and gate_model is not None and gate_feature_names is not None and trust_threshold is not None:
        feature_row = pd.DataFrame([{
            "ann_std_vhat": ann_std_vhat,
            "ann_shift_from_coarse": ann_shift_from_coarse,
            "coarse_top_gap_ratio": coarse_top_gap_ratio,
            "ambiguity_flag": ambiguity_flag,
            "multi_peak_count": multi_peak_count,
            "ensemble_range_vhat": ensemble_range_vhat,
        }])[gate_feature_names].values

        trust_prob = float(gate_model.predict_proba(feature_row)[0, 1])
        trust_ann = bool(trust_prob >= trust_threshold)

    chosen_vhat = ann_vhat if trust_ann else coarse_best_vhat
    V_pred = float(np.clip(chosen_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))

    return {
        "feature": feat,
        "V_pred": V_pred,
        "P_pred": float(V_pred * oracle.measure(V_pred)),
        "pred_vhat_mean": ann_vhat,
        "pred_vhat_std": ann_std_vhat,
        "pred_vhat_min": float(ens["min_vhat"]),
        "pred_vhat_max": float(ens["max_vhat"]),
        "trust_prob": trust_prob,
        "trust_ann": trust_ann,
        "coarse_best_vhat": coarse_best_vhat,
    }

def compute_raw_predictions_for_oracle(
    oracle,
    models,
    mu,
    sd,
    residual_scale,
    cfg,
    gate_model=None,
    gate_feature_names=None,
    trust_threshold=None,
):
    ann_info = predict_ann_stage_for_oracle(oracle, models, mu, sd, residual_scale, cfg)
    feat = ann_info["feature"]
    coarse_vhat = float(feat["coarse_best_vhat"])
    raw_ann_vhat = float(ann_info["pred_vhat_mean"])

    V_raw_ann = float(np.clip(raw_ann_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
    V_coarse = float(np.clip(coarse_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))

    P_raw_ann = float(V_raw_ann * oracle.measure(V_raw_ann))
    P_coarse = float(V_coarse * oracle.measure(V_coarse))

    return {
        "V_raw_ann": V_raw_ann,
        "P_raw_ann": P_raw_ann,
        "V_coarse": V_coarse,
        "P_coarse": P_coarse,
        "V_gated": V_raw_ann,
        "P_gated": P_raw_ann,
        "trust_ann": True,
        "trust_prob": None,
        "ann_std_vhat": float(ann_info["pred_vhat_std"]),
        "raw_ann_vhat": raw_ann_vhat,
        "coarse_vhat": coarse_vhat,
        "gated_vhat": raw_ann_vhat,
    }

def compute_raw_and_gated_predictions_for_oracle(
    oracle,
    models,
    mu,
    sd,
    residual_scale,
    cfg,
    gate_model=None,
    gate_feature_names=None,
    trust_threshold=None,
):
    v, i = oracle.curve_for_plot()
    feat = build_feature_vector(v, i, cfg.sample_fracs)
    x = feat["x"][None, :]
    x_std = apply_standardizer(x, mu, sd)

    coarse_best_vhat = float(feat["coarse_best_vhat"])
    coarse_top_gap_ratio = float(feat["top_gap_ratio"])
    ambiguity_flag = float(feat["ambiguity_flag"])
    multi_peak_count = float(feat["multi_peak_count"])

    ens = predict_vhat_ensemble(models, x_std, coarse_best_vhat, residual_scale, cfg.device)

    ann_vhat = float(ens["mean_vhat"])
    ann_std_vhat = float(ens["std_vhat"])
    ensemble_range_vhat = float(ens["max_vhat"] - ens["min_vhat"])
    ann_shift_from_coarse = abs(ann_vhat - coarse_best_vhat)

    trust_prob = None
    trust_ann = True

    if cfg.trust_gate_enabled and gate_model is not None and gate_feature_names is not None and trust_threshold is not None:
        feature_row = pd.DataFrame([{
            "ann_std_vhat": ann_std_vhat,
            "ann_shift_from_coarse": ann_shift_from_coarse,
            "coarse_top_gap_ratio": coarse_top_gap_ratio,
            "ambiguity_flag": ambiguity_flag,
            "multi_peak_count": multi_peak_count,
            "ensemble_range_vhat": ensemble_range_vhat,
        }])[gate_feature_names].values

        trust_prob = float(gate_model.predict_proba(feature_row)[0, 1])
        trust_ann = bool(trust_prob >= trust_threshold)

    raw_ann_vhat = ann_vhat
    coarse_vhat = coarse_best_vhat
    chosen_vhat = raw_ann_vhat if trust_ann else coarse_vhat

    V_raw_ann = float(np.clip(raw_ann_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
    V_coarse = float(np.clip(coarse_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))
    V_gated = float(np.clip(chosen_vhat * oracle.voc, cfg.sample_fracs_min * oracle.voc, cfg.sample_fracs_max * oracle.voc))

    P_raw_ann = float(V_raw_ann * oracle.measure(V_raw_ann))
    P_coarse = float(V_coarse * oracle.measure(V_coarse))
    P_gated = float(V_gated * oracle.measure(V_gated))

    return {
        "V_raw_ann": V_raw_ann,
        "P_raw_ann": P_raw_ann,
        "V_coarse": V_coarse,
        "P_coarse": P_coarse,
        "V_gated": V_gated,
        "P_gated": P_gated,
        "trust_ann": trust_ann,
        "trust_prob": trust_prob,
        "ann_std_vhat": ann_std_vhat,
        "raw_ann_vhat": raw_ann_vhat,
        "coarse_vhat": coarse_vhat,
        "gated_vhat": chosen_vhat,
    }

def get_runtime_tuning(cfg: Config) -> Dict[str, object]:
    if cfg.use_lean_global_runtime:
        return {
            "max_refine_iterations": cfg.max_refine_iterations,
            "dual_rescue_offsets": cfg.dual_rescue_offsets,
            "widen_scan_steps": cfg.widen_scan_steps,
            "enable_top3_rescue": cfg.enable_top3_rescue,
        }
    return {
        "max_refine_iterations": max(cfg.max_refine_iterations, 10),
        "dual_rescue_offsets": (-0.06, -0.03, 0.0, 0.03, 0.06),
        "widen_scan_steps": max(cfg.widen_scan_steps, 10),
        "enable_top3_rescue": True,
    }

def run_global_gmppt_episode_logged(
    oracle: CurveOracle,
    models,
    mu: np.ndarray,
    sd: np.ndarray,
    residual_scale: float,
    cfg: Config,
    gate_model=None,
    gate_feature_names=None,
    trust_threshold=None,
):
    stats = StageStats()
    runtime = get_runtime_tuning(cfg)
    max_refine_iterations = int(runtime["max_refine_iterations"])
    dual_rescue_offsets = tuple(runtime["dual_rescue_offsets"])
    widen_scan_steps = int(runtime["widen_scan_steps"])
    enable_top3_rescue = bool(runtime["enable_top3_rescue"])

    if oracle.voc <= 0 or oracle.pmpp_true <= 0:
        return {"eff": 0.0, "ratio": 0.0, "time": 0.0, "fallback": False, "trust_ann": True}, {
            "Voc": 0.0,
            "Isc": 0.0,
            "coarse_V": [],
            "coarse_P": [],
            "meas_V": [],
            "meas_P": [],
            "meas_tag": [],
            "fallback": False,
            "ambiguous_case": False,
            "uncertain_ann": False,
            "dual_peak_rescue_used": False,
            "top3_rescue_used": False,
            "V_target": 0.0,
            "P_target": 0.0,
            "V_best": 0.0,
            "P_best": 0.0,
            "V_coarse_best": 0.0,
            "P_coarse_best": 0.0,
            "V_second_coarse": 0.0,
            "P_second_coarse": 0.0,
            "V_third_coarse": 0.0,
            "P_third_coarse": 0.0,
            "mode": "global",
            "log_trust_prob": None,
            "log_trust_ann": True,
            "stage_stats": stats.__dict__.copy(),
            "total_probe_time": 0.0,
            "total_hold_time": 0.0,
        }

    Voc = oracle.voc
    Isc = max(oracle.measure(0.0), 1e-9)

    V_best = 0.80 * Voc
    P_best = V_best * oracle.measure(V_best)
    E, t, hold_dt = add_adaptive_hold(0.0, 0.0, P_best, P_best, cfg)
    stats.t_hold_total += hold_dt

    log = {
        "Voc": Voc,
        "Isc": Isc,
        "coarse_V": [],
        "coarse_P": [],
        "meas_V": [],
        "meas_P": [],
        "meas_tag": [],
        "fallback": False,
        "ambiguous_case": False,
        "uncertain_ann": False,
        "dual_peak_rescue_used": False,
        "top3_rescue_used": False,
        "mode": "global",
        "log_trust_prob": None,
        "log_trust_ann": True,
    }

    # 1) coarse sweep
    V_coarse = (cfg.sample_fracs * Voc).astype(float)
    I_coarse = np.array([oracle.measure(vq) for vq in V_coarse], dtype=float)
    P_coarse = V_coarse * I_coarse
    log["coarse_V"] = V_coarse.tolist()
    log["coarse_P"] = P_coarse.tolist()

    amb_info = detect_ambiguity_from_coarse(V_coarse, P_coarse, cfg)
    best_idx = int(amb_info["best_idx"])
    second_idx = int(amb_info["second_idx"])
    third_idx = int(amb_info["third_idx"])
    ambiguous_case = bool(amb_info["ambiguous"])

    V_coarse_best = float(V_coarse[best_idx]) if len(P_coarse) else 0.0
    P_coarse_best = float(P_coarse[best_idx]) if len(P_coarse) else 0.0
    V_second = float(V_coarse[second_idx]) if len(P_coarse) > 1 else V_coarse_best
    P_second = float(P_coarse[second_idx]) if len(P_coarse) > 1 else P_coarse_best
    V_third = float(V_coarse[third_idx]) if len(P_coarse) > 2 else V_second
    P_third = float(P_coarse[third_idx]) if len(P_coarse) > 2 else P_second

    log["V_coarse_best"] = V_coarse_best
    log["P_coarse_best"] = P_coarse_best
    log["V_second_coarse"] = V_second
    log["P_second_coarse"] = P_second
    log["V_third_coarse"] = V_third
    log["P_third_coarse"] = P_third
    log["ambiguous_case"] = ambiguous_case
    log["coarse_gap_ratio"] = float(amb_info["gap_ratio"])
    log["coarse_sep_frac"] = float(amb_info["sep_frac"])
    log["coarse_n_local_max"] = int(amb_info["n_local_max"])

    for vq, pq in zip(V_coarse, P_coarse):
        E, t = add_probe(E, t, float(pq), cfg.dt_meas)
        stats.coarse_points += 1
        stats.t_probe_total += cfg.dt_meas
        log["meas_V"].append(float(vq))
        log["meas_P"].append(float(pq))
        log["meas_tag"].append("coarse")
        p_before = P_best
        V_best, P_best, _ = maybe_update_best(float(vq), float(pq), V_best, P_best)
        E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
        stats.t_hold_total += hold_dt

    # 2) ANN stage
    ann_info = predict_ann_stage_with_trust_gate(
        oracle,
        models,
        mu,
        sd,
        residual_scale,
        cfg,
        gate_model=gate_model,
        gate_feature_names=gate_feature_names,
        trust_threshold=trust_threshold,
    )
    V_target = ann_info["V_pred"]
    P_target = ann_info["P_pred"]
    uncertain_ann = bool(ann_info["pred_vhat_std"] >= cfg.uncertainty_std_thresh)

    log["V_target"] = V_target
    log["P_target"] = P_target
    log["ann_pred_std_vhat"] = float(ann_info["pred_vhat_std"])
    log["uncertain_ann"] = uncertain_ann
    log["log_trust_prob"] = ann_info["trust_prob"]
    log["log_trust_ann"] = ann_info["trust_ann"]

    E, t = add_probe(E, t, P_target, cfg.dt_meas)
    stats.ann_points += 1
    stats.t_probe_total += cfg.dt_meas
    log["meas_V"].append(float(V_target))
    log["meas_P"].append(float(P_target))
    log["meas_tag"].append("ann")
    p_before = P_best
    V_best, P_best, _ = maybe_update_best(V_target, P_target, V_best, P_best)
    E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
    stats.t_hold_total += hold_dt

    # 3) local refine
    delta = cfg.delta_local
    for _ in range(max_refine_iterations):
        p_round_start = P_best
        improved = False
        candidates = [
            float(np.clip(V_best * (1.0 - delta), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
            float(np.clip(V_best * (1.0 + delta), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
        ]
        for vq in candidates:
            pq = vq * oracle.measure(vq)
            E, t = add_probe(E, t, pq, cfg.dt_meas)
            stats.refine_points += 1
            stats.t_probe_total += cfg.dt_meas
            log["meas_V"].append(float(vq))
            log["meas_P"].append(float(pq))
            log["meas_tag"].append("local_refine")
            old_p = P_best
            V_best, P_best, better = maybe_update_best(float(vq), float(pq), V_best, P_best)
            improved = improved or better or (P_best > old_p)
            E, t, hold_dt = add_adaptive_hold(E, t, old_p, P_best, cfg)
            stats.t_hold_total += hold_dt

        round_gain = (P_best - p_round_start) / max(p_round_start, 1e-9)
        if round_gain < cfg.min_refine_gain_ratio:
            break

        if not improved:
            if delta > 0.0125:
                delta /= 2.0
            else:
                break

    # 4) dual-peak rescue
    dual_peak_trigger = ambiguous_case or uncertain_ann
    if cfg.enable_dual_peak_rescue and dual_peak_trigger:
        log["dual_peak_rescue_used"] = True
        candidate_centers = [V_coarse_best]
        if cfg.rescue_use_second_peak:
            candidate_centers.append(V_second)
        candidate_centers.append(V_target)

        E, t, V_best, P_best = run_targeted_rescue(
            oracle=oracle,
            candidate_centers=candidate_centers,
            offsets=dual_rescue_offsets,
            cfg=cfg,
            E=E,
            t=t,
            log=log,
            V_best=V_best,
            P_best=P_best,
            tag="dual_peak_rescue",
            stats=stats,
        )

    # 5) NEW: top-3 rare-case rescue
    coarse_best = float(np.max(P_coarse)) if len(P_coarse) else 0.0
    suspicious_case = (
        ambiguous_case
        or uncertain_ann
        or count_local_maxima(P_coarse, noise_tolerance=0.02) >= cfg.top3_localmax_threshold
        or (P_best < cfg.top3_trigger_power_ratio * coarse_best)
    )

    if enable_top3_rescue and suspicious_case:
        log["top3_rescue_used"] = True
        order_desc = np.argsort(P_coarse)[::-1]
        top_k = min(3, len(order_desc))
        candidate_centers = [float(V_coarse[idx]) for idx in order_desc[:top_k]]
        candidate_centers.extend([V_target, V_best])

        E, t, V_best, P_best = run_targeted_rescue(
            oracle=oracle,
            candidate_centers=candidate_centers,
            offsets=cfg.top3_rescue_offsets,
            cfg=cfg,
            E=E,
            t=t,
            log=log,
            V_best=V_best,
            P_best=P_best,
            tag="top3_rescue",
            stats=stats,
        )

    # 6) fallback safety logic
    weak_vs_coarse = P_best < cfg.fallback_power_ratio_thresh * coarse_best
    fallback_trigger = weak_vs_coarse or (ambiguous_case and uncertain_ann)

    if fallback_trigger:
        log["fallback"] = True

        if cfg.enable_targeted_fallback_first:
            fallback_centers = [V_coarse_best, V_second, V_third, V_target, V_best]
            E, t, V_best, P_best = run_targeted_rescue(
                oracle=oracle,
                candidate_centers=fallback_centers,
                offsets=dual_rescue_offsets,
                cfg=cfg,
                E=E,
                t=t,
                log=log,
                V_best=V_best,
                P_best=P_best,
                tag="fallback_targeted",
                stats=stats,
            )

        if P_best < cfg.fallback_power_ratio_thresh * coarse_best:
            for frac in np.linspace(0.15, 0.90, widen_scan_steps):
                vq = float(frac * Voc)
                pq = vq * oracle.measure(vq)
                E, t = add_probe(E, t, pq, cfg.dt_meas)
                stats.fallback_wide_points += 1
                stats.t_probe_total += cfg.dt_meas
                log["meas_V"].append(float(vq))
                log["meas_P"].append(float(pq))
                log["meas_tag"].append("fallback_wide")
                p_before = P_best
                V_best, P_best, _ = maybe_update_best(vq, pq, V_best, P_best)
                E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
                stats.t_hold_total += hold_dt

    log["V_best"] = V_best
    log["P_best"] = P_best
    log["stage_stats"] = stats.__dict__.copy()
    log["total_probe_time"] = float(stats.t_probe_total)
    log["total_hold_time"] = float(stats.t_hold_total)
    log["episode_time"] = float(t)

    result = {
        "eff": E / (oracle.pmpp_true * t + 1e-12),
        "ratio": P_best / (oracle.pmpp_true + 1e-12),
        "time": t,
        "fallback": log["fallback"],
        "ambiguous_case": log["ambiguous_case"],
        "uncertain_ann": log["uncertain_ann"],
        "dual_peak_rescue_used": log["dual_peak_rescue_used"],
        "top3_rescue_used": log["top3_rescue_used"],
        "trust_ann": log["log_trust_ann"],
        "mode": "global",
        "total_probe_time": float(stats.t_probe_total),
        "total_hold_time": float(stats.t_hold_total),
        "stage_stats": stats.__dict__.copy(),
    }
    return result, log

def shading_change_detected(p_now, p_prev, cfg):
    dP = abs(p_now - p_prev) / max(abs(p_prev), 1e-9)
    return dP >= cfg.event_trigger_power_delta_ratio

def run_local_track_episode_logged(oracle: CurveOracle, state: RuntimeState, cfg: Config):
    stats = StageStats()
    Voc = oracle.voc
    V_center = float(np.clip(state.last_v_best, cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc))
    candidates = [
        float(np.clip(V_center * (1.0 - cfg.local_track_delta_ratio), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
        V_center,
        float(np.clip(V_center * (1.0 + cfg.local_track_delta_ratio), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
    ]
    E, t = 0.0, 0.0
    V_best = V_center
    P_best = V_center * oracle.measure(V_center)
    for vq in candidates:
        pq = vq * oracle.measure(vq)
        E, t = add_probe(E, t, pq, cfg.dt_meas)
        stats.refine_points += 1
        stats.t_probe_total += cfg.dt_meas
        p_before = P_best
        V_best, P_best, _ = maybe_update_best(vq, pq, V_best, P_best)
        E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
        stats.t_hold_total += hold_dt

    # one optional extra local check
    probe_v = float(np.clip(V_best * (1.0 + 0.5 * cfg.local_track_delta_ratio), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc))
    probe_p = probe_v * oracle.measure(probe_v)
    gain_ratio = (probe_p - P_best) / max(P_best, 1e-9)
    if gain_ratio >= cfg.min_refine_gain_ratio:
        E, t = add_probe(E, t, probe_p, cfg.dt_meas)
        stats.refine_points += 1
        stats.t_probe_total += cfg.dt_meas
        p_before = P_best
        V_best, P_best, _ = maybe_update_best(probe_v, probe_p, V_best, P_best)
        E, t, hold_dt = add_adaptive_hold(E, t, p_before, P_best, cfg)
        stats.t_hold_total += hold_dt

    log = {
        "mode": "local",
        "fallback": False,
        "dual_peak_rescue_used": False,
        "top3_rescue_used": False,
        "V_best": float(V_best),
        "P_best": float(P_best),
        "stage_stats": stats.__dict__.copy(),
        "total_probe_time": float(stats.t_probe_total),
        "total_hold_time": float(stats.t_hold_total),
        "episode_time": float(t),
    }
    result = {
        "eff": E / (oracle.pmpp_true * t + 1e-12),
        "ratio": P_best / (oracle.pmpp_true + 1e-12),
        "time": t,
        "fallback": False,
        "ambiguous_case": False,
        "uncertain_ann": False,
        "dual_peak_rescue_used": False,
        "top3_rescue_used": False,
        "mode": "local",
        "total_probe_time": float(stats.t_probe_total),
        "total_hold_time": float(stats.t_hold_total),
        "stage_stats": stats.__dict__.copy(),
    }
    return result, log

def run_supervisory_controller_step(
    oracle, state, models, mu, sd, residual_scale, cfg,
    gate_model=None, gate_feature_names=None, trust_threshold=None
):
    if not state.initialized:
        result, log = run_global_gmppt_episode_logged(
            oracle, models, mu, sd, residual_scale, cfg,
            gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
        )
    else:
        v_observed = state.last_v_best
        p_observed = float(v_observed * oracle.measure(v_observed))
        prev_p = state.last_p_observed if state.last_p_observed is not None else state.last_p_best
        should_run_local = cfg.use_event_triggered_global and not shading_change_detected(
            p_observed, prev_p, cfg
        )
        if should_run_local:
            result, log = run_local_track_episode_logged(oracle, state, cfg)
        else:
            result, log = run_global_gmppt_episode_logged(
                oracle, models, mu, sd, residual_scale, cfg,
                gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
            )

    state.initialized = True
    state.last_v_best = log["V_best"]
    state.last_p_best = log["P_best"]
    state.last_mode = log["mode"]
    state.last_v_observed = state.last_v_best
    state.last_p_observed = state.last_p_best
    return result, log, state

def run_hybrid_supervised_step(
    oracle, state, models, mu, sd, residual_scale, cfg,
    gate_model=None, gate_feature_names=None, trust_threshold=None
):
    result, log, state = run_supervisory_controller_step(
        oracle, state, models, mu, sd, residual_scale, cfg,
        gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
    )
    return result, log, state

def run_hybrid_episode_logged_baseline(
    oracle: CurveOracle, models, mu: np.ndarray, sd: np.ndarray, residual_scale: float, cfg: Config,
    gate_model=None, gate_feature_names=None, trust_threshold=None
):
    stats = StageStats()
    if oracle.voc <= 0 or oracle.pmpp_true <= 0:
        return {"eff": 0.0, "ratio": 0.0, "time": 0.0, "fallback": False, "trust_ann": True}, {
            "Voc": 0.0, "Isc": 0.0, "coarse_V": [], "coarse_P": [], "meas_V": [], "meas_P": [],
            "meas_tag": [], "fallback": False, "ambiguous_case": False, "uncertain_ann": False,
            "dual_peak_rescue_used": False, "top3_rescue_used": False, "V_target": 0.0, "P_target": 0.0,
            "V_best": 0.0, "P_best": 0.0, "V_coarse_best": 0.0, "P_coarse_best": 0.0, "mode": "global",
            "log_trust_prob": None, "log_trust_ann": True, "stage_stats": stats.__dict__.copy(),
            "total_probe_time": 0.0, "total_hold_time": 0.0,
        }

    Voc = oracle.voc
    Isc = max(oracle.measure(0.0), 1e-9)
    V_best = 0.80 * Voc
    P_best = V_best * oracle.measure(V_best)
    E, t = add_hold(0.0, 0.0, P_best, cfg.dt_hold)
    stats.t_hold_total += cfg.dt_hold

    log = {
        "Voc": Voc, "Isc": Isc, "coarse_V": [], "coarse_P": [], "meas_V": [], "meas_P": [], "meas_tag": [],
        "fallback": False, "ambiguous_case": False, "uncertain_ann": False,
        "dual_peak_rescue_used": False, "top3_rescue_used": False, "mode": "global",
        "log_trust_prob": None, "log_trust_ann": True,
    }

    V_coarse = (cfg.sample_fracs * Voc).astype(float)
    I_coarse = np.array([oracle.measure(vq) for vq in V_coarse], dtype=float)
    P_coarse = V_coarse * I_coarse
    log["coarse_V"] = V_coarse.tolist()
    log["coarse_P"] = P_coarse.tolist()

    best_idx = int(np.argmax(P_coarse)) if len(P_coarse) else 0
    V_coarse_best = float(V_coarse[best_idx]) if len(P_coarse) else 0.0
    P_coarse_best = float(P_coarse[best_idx]) if len(P_coarse) else 0.0
    log["V_coarse_best"] = V_coarse_best
    log["P_coarse_best"] = P_coarse_best

    for vq, pq in zip(V_coarse, P_coarse):
        E, t = add_probe(E, t, float(pq), cfg.dt_meas)
        stats.coarse_points += 1
        stats.t_probe_total += cfg.dt_meas
        log["meas_V"].append(float(vq)); log["meas_P"].append(float(pq)); log["meas_tag"].append("coarse")
        p_before = P_best
        V_best, P_best, _ = maybe_update_best(float(vq), float(pq), V_best, P_best)
        E, t = add_hold(E, t, P_best, cfg.dt_hold)
        stats.t_hold_total += cfg.dt_hold

    ann_info = predict_ann_stage_for_oracle(oracle, models, mu, sd, residual_scale, cfg)
    V_target = ann_info["V_pred"]; P_target = ann_info["P_pred"]
    log["V_target"] = V_target; log["P_target"] = P_target
    log["ann_pred_std_vhat"] = float(ann_info["pred_vhat_std"])

    E, t = add_probe(E, t, P_target, cfg.dt_meas)
    stats.ann_points += 1; stats.t_probe_total += cfg.dt_meas
    log["meas_V"].append(float(V_target)); log["meas_P"].append(float(P_target)); log["meas_tag"].append("ann")
    p_before = P_best
    V_best, P_best, _ = maybe_update_best(V_target, P_target, V_best, P_best)
    E, t = add_hold(E, t, P_best, cfg.dt_hold)
    stats.t_hold_total += cfg.dt_hold

    delta = cfg.delta_local
    for _ in range(cfg.max_refine_iterations):
        p_round_start = P_best
        improved = False
        candidates = [
            float(np.clip(V_best * (1.0 - delta), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
            float(np.clip(V_best * (1.0 + delta), cfg.sample_fracs_min * Voc, cfg.sample_fracs_max * Voc)),
        ]
        for vq in candidates:
            pq = vq * oracle.measure(vq)
            E, t = add_probe(E, t, pq, cfg.dt_meas)
            stats.refine_points += 1; stats.t_probe_total += cfg.dt_meas
            log["meas_V"].append(float(vq)); log["meas_P"].append(float(pq)); log["meas_tag"].append("local_refine")
            old_p = P_best
            V_best, P_best, better = maybe_update_best(float(vq), float(pq), V_best, P_best)
            improved = improved or better or (P_best > old_p)
            E, t = add_hold(E, t, P_best, cfg.dt_hold)
            stats.t_hold_total += cfg.dt_hold
        if (P_best - p_round_start) / max(p_round_start, 1e-9) < cfg.min_refine_gain_ratio:
            break
        if not improved:
            if delta > 0.0125: delta /= 2.0
            else: break

    coarse_best = float(np.max(P_coarse)) if len(P_coarse) else 0.0
    baseline_local_max_count = count_local_maxima(P_coarse, noise_tolerance=0.02)
    fallback_trigger = (
        baseline_local_max_count >= cfg.shading_peak_threshold
        or (P_best < 0.90 * coarse_best)
    )
    if fallback_trigger:
        log["fallback"] = True
        for frac in np.linspace(0.15, 0.90, cfg.widen_scan_steps):
            vq = float(frac * Voc); pq = vq * oracle.measure(vq)
            E, t = add_probe(E, t, pq, cfg.dt_meas)
            stats.fallback_wide_points += 1; stats.t_probe_total += cfg.dt_meas
            log["meas_V"].append(float(vq)); log["meas_P"].append(float(pq)); log["meas_tag"].append("fallback_wide")
            p_before = P_best
            V_best, P_best, _ = maybe_update_best(vq, pq, V_best, P_best)
            E, t = add_hold(E, t, P_best, cfg.dt_hold)
            stats.t_hold_total += cfg.dt_hold

    log["V_best"] = V_best; log["P_best"] = P_best
    log["stage_stats"] = stats.__dict__.copy(); log["total_probe_time"] = float(stats.t_probe_total)
    log["total_hold_time"] = float(stats.t_hold_total); log["episode_time"] = float(t)
    result = {
        "eff": E / (oracle.pmpp_true * t + 1e-12), "ratio": P_best / (oracle.pmpp_true + 1e-12), "time": t,
        "fallback": log["fallback"], "ambiguous_case": False, "uncertain_ann": False,
        "dual_peak_rescue_used": False, "top3_rescue_used": False, "trust_ann": True, "mode": "global",
        "total_probe_time": float(stats.t_probe_total), "total_hold_time": float(stats.t_hold_total),
        "stage_stats": stats.__dict__.copy(),
    }
    return result, log


def run_hybrid_episode_logged_extended(
    oracle: CurveOracle, models, mu: np.ndarray, sd: np.ndarray, residual_scale: float, cfg: Config,
    gate_model=None, gate_feature_names=None, trust_threshold=None
):
    return run_global_gmppt_episode_logged(
        oracle, models, mu, sd, residual_scale, cfg,
        gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
    )


def run_hybrid_episode_logged(
    oracle: CurveOracle, models, mu: np.ndarray, sd: np.ndarray, residual_scale: float, cfg: Config,
    gate_model=None, gate_feature_names=None, trust_threshold=None
):
    if cfg.trust_gate_enabled:
        return run_hybrid_episode_logged_extended(
            oracle, models, mu, sd, residual_scale, cfg,
            gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
        )
    return run_hybrid_episode_logged_baseline(
        oracle, models, mu, sd, residual_scale, cfg,
        gate_model=gate_model, gate_feature_names=gate_feature_names, trust_threshold=trust_threshold
    )

