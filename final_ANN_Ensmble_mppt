def estimate_power_at_predicted_vhat(pred_vhat, seq_x):
    v = seq_x[:, :, 0]
    p = seq_x[:, :, 2]
    dist = torch.abs(v - pred_vhat.unsqueeze(-1))
    idx = torch.argmin(dist, dim=1)
    p_pick = p[torch.arange(p.shape[0], device=p.device), idx]
    return p_pick

def supervised_power_first_loss(pred_vhat, true_vhat, true_power_ratio, coarse_vhat, seq_x, cfg: Config):
    pred_power_ratio = estimate_power_at_predicted_vhat(pred_vhat, seq_x)
    coarse_power_ratio = estimate_power_at_predicted_vhat(coarse_vhat, seq_x)
    l_voltage = nn.SmoothL1Loss()(pred_vhat, true_vhat)
    l_power = nn.SmoothL1Loss()(pred_power_ratio, true_power_ratio)
    l_rank = torch.relu(coarse_power_ratio - pred_power_ratio).mean()
    total = cfg.w_v * l_voltage + cfg.w_p * l_power + cfg.w_rank * l_rank
    return total, {"L_voltage": l_voltage.item(), "L_power": l_power.item(), "L_rank": l_rank.item()}

def pinn_loss(pred_vhat, true_vhat, true_power_ratio, coarse_vhat, seq_x, cfg: Config):
    pred_vhat = pred_vhat.requires_grad_(True)
    pred_power_ratio = estimate_power_at_predicted_vhat(pred_vhat, seq_x)
    l_voltage = nn.SmoothL1Loss()(pred_vhat, true_vhat)
    l_power = nn.SmoothL1Loss()(pred_power_ratio, true_power_ratio)
    grad = torch.autograd.grad(pred_power_ratio.sum(), pred_vhat, create_graph=True, retain_graph=True)[0]
    l_mpp = (grad ** 2).mean()
    l_bound = (torch.relu(-pred_vhat) + torch.relu(pred_vhat - 1.0)).mean()
    l_phys = ((pred_power_ratio - seq_x[:, :, 2].max(dim=1).values) ** 2).mean()
    total = cfg.w_data * (l_voltage + l_power) + cfg.w_phys * l_phys + cfg.w_mpp * l_mpp + cfg.w_bound * l_bound
    return total

def single_diode_residual(pred_vhat, seq_x, cfg: Config, aux_params: Dict[str, torch.Tensor]):
    if aux_params is None:
        raise ValueError("mamba_pinn is not enabled until real diode-physics residuals are implemented")
    required = ("voc", "isc")
    for k in required:
        if k not in aux_params:
            raise ValueError("mamba_pinn is not enabled until real diode-physics residuals are implemented")
        if torch.isnan(aux_params[k]).any():
            raise ValueError("mamba_pinn is not enabled until real diode-physics residuals are implemented")
    raise ValueError("mamba_pinn is not enabled until real diode-physics residuals are implemented")

