def split_curves_train_val_test(curves, train_ratio=0.70, val_ratio=0.15, seed=7):
    curve_list = list(iter_curve_items(curves))
    rng = np.random.default_rng(seed)
    idx = np.arange(len(curve_list))
    rng.shuffle(idx)
    n = len(idx)
    n_train = int(train_ratio * n)
    n_val = int(val_ratio * n)
    tr = [curve_list[i] for i in idx[:n_train]]
    va = [curve_list[i] for i in idx[n_train:n_train + n_val]]
    te = [curve_list[i] for i in idx[n_train + n_val:]]
    return tr, va, te

def augment_curve_psc(v: np.ndarray, i: np.ndarray, rng: np.random.Generator, test_only_unseen=False):
    v2 = np.asarray(v, dtype=np.float32).copy()
    i2 = np.asarray(i, dtype=np.float32).copy()
    if len(v2) < 8:
        return v2, i2
    # random irradiance scaling on sub-strings
    n_seg = int(rng.integers(2, 5))
    seg = np.array_split(np.arange(len(i2)), n_seg)
    for ids in seg:
        i2[ids] *= float(rng.uniform(0.65, 1.05))
    # random current drop segments
    for _ in range(int(rng.integers(1, 4))):
        a = int(rng.integers(0, len(i2) - 2)); b = int(rng.integers(a + 1, len(i2)))
        i2[a:b] *= float(rng.uniform(0.55, 0.95))
    # random local noise
    i2 += rng.normal(0.0, 0.01 * max(float(np.max(np.abs(i2))), 1e-6), size=i2.shape).astype(np.float32)
    # random voltage-axis compression/expansion
    v2 *= float(rng.uniform(0.9, 1.1))
    if test_only_unseen:
        for _ in range(2):
            a = int(rng.integers(0, len(i2)-3)); b = int(min(len(i2), a + rng.integers(2, 6)))
            i2[a:b] *= float(rng.uniform(0.4, 0.8))
    return v2, np.maximum(i2, 0.0)

def build_sequence_dataset_from_curves(curves, sample_fracs: np.ndarray, cfg: Config, augment=False, test_only_unseen=False):
    X_seq, y_vhat, y_power, y_coarse = [], [], [], []
    meta = {"coarse_ratio_pct": [], "coarse_diff_pct": [], "multi_peak_count": [], "ambiguity_flag": []}
    rng = np.random.default_rng(cfg.seed + (13 if augment else 0))
    aux = {"voc": [], "isc": [], "rs": [], "rsh": [], "temperature": []}

    for item in list(iter_curve_items(curves)):
        v_raw, i_raw = extract_vi(item)
        if v_raw is None or i_raw is None:
            continue
        v, i = clean_iv_curve(v_raw, i_raw)
        if len(v) < 5 or not validate_cleaned_curve(v, i):
            continue
        if augment:
            v, i = augment_curve_psc(v, i, rng, test_only_unseen=test_only_unseen)
            v, i = clean_iv_curve(v, i)
            if len(v) < 5 or not validate_cleaned_curve(v, i):
                continue

        oracle = CurveOracle(np.stack([v, i], axis=0))
        feat = build_feature_vector(v, i, sample_fracs)
        voc = max(float(oracle.voc), 1e-6)
        isc = max(float(oracle.isc), 1e-6)

        vq = sample_fracs.astype(np.float32)
        vv = np.clip(vq * voc, np.min(v), np.max(v))
        ii = np.interp(vv, v, i).astype(np.float32)
        i_norm = ii / isc
        p_norm = (vq * i_norm).astype(np.float32)
        dpdv_local = np.gradient(p_norm, vq, edge_order=1).astype(np.float32)
        delta_i_next = np.zeros_like(i_norm, dtype=np.float32)
        delta_i_next[:-1] = i_norm[1:] - i_norm[:-1]

        x_step = np.stack([vq, i_norm, p_norm, dpdv_local, delta_i_next], axis=-1).astype(np.float32)

        X_seq.append(x_step)
        y_vhat.append(np.float32(oracle.vmpp_true / voc))
        y_power.append(np.float32(oracle.pmpp_true / (voc * isc)))
        y_coarse.append(np.float32(feat["coarse_best_vhat"]))

        coarse_v = float(feat["coarse_best_vhat"]) * voc
        coarse_p = coarse_v * float(np.interp(coarse_v, v, i))
        meta["coarse_ratio_pct"].append(np.float32(100.0 * coarse_p / max(oracle.pmpp_true, 1e-9)))
        meta["coarse_diff_pct"].append(np.float32(100.0 * abs((coarse_v - oracle.vmpp_true) / max(oracle.vmpp_true, 1e-9))))
        meta["multi_peak_count"].append(np.float32(feat["multi_peak_count"]))
        meta["ambiguity_flag"].append(np.float32(feat["ambiguity_flag"]))
        aux["voc"].append(np.float32(oracle.voc))
        aux["isc"].append(np.float32(oracle.isc))
        aux["rs"].append(np.float32(np.nan))
        aux["rsh"].append(np.float32(np.nan))
        aux["temperature"].append(np.float32(np.nan))

    return {
        "X_seq": np.asarray(X_seq, dtype=np.float32),
        "y_vhat_true": np.asarray(y_vhat, dtype=np.float32),
        "y_power_true": np.asarray(y_power, dtype=np.float32),
        "y_coarse_vhat": np.asarray(y_coarse, dtype=np.float32),
        **{k: np.asarray(v, dtype=np.float32) for k, v in meta.items()},
        **{f"aux_{k}": np.asarray(v, dtype=np.float32) for k, v in aux.items()},
    }

